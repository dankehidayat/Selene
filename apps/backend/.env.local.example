# [apps/backend] .env.local.example
# Copy this file to .env for local development (Prisma also loads .env here)

PORT=8787
JWT_SECRET="local_dev_jwt_secret_change_me"

# Postgres is on host port 5434 (not 5432). Port 5432 is commonly used by
# Homebrew postgresql@14; connecting there yields Prisma P1010 because the
# brew instance has no `selene` database / `selene_admin` role.
DATABASE_URL=postgresql://selene_admin:local_dev_password@127.0.0.1:5434/selene?schema=public

# Timescale stays on 5433 (no brew conflict in typical setups)
TIMESCALE_URL=postgresql://selene_ts:local_dev_password@127.0.0.1:5433/selene_measurements

# ── MQTT ──────────────────────────────────────────────────
# Live ESP32 data without changing Arduino (device stays on VPS):
#   1. ssh -N -L 1884:127.0.0.1:1883 rd
#   2. Use MQTT_HOST/PORT below (tunnel)
#   3. bun run dev
#
# Local-only EMQX (docker-compose.local.yml) instead:
#   MQTT_HOST=127.0.0.1
#   MQTT_PORT=1883
MQTT_HOST=127.0.0.1
MQTT_PORT=1884
MQTT_TOPIC=selene/+/telemetry
MQTT_USER=selene
MQTT_PASSWORD=selene123
