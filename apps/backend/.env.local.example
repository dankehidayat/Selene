# LOCAL Mac — copy to apps/backend/.env for `bun run dev`
# Matches docker-compose.local.yml ports (Postgres 5434, Timescale 5433)

PORT=8787
JWT_SECRET="local_dev_jwt_secret_change_me"
DATABASE_URL=postgresql://selene_admin:local_dev_password@127.0.0.1:5434/selene?schema=public
TIMESCALE_URL=postgresql://selene_ts:local_dev_password@127.0.0.1:5433/selene_measurements

# Local EMQX: 1883  |  VPS live data via tunnel: ./scripts/mqtt-tunnel.sh → 1884
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_TOPIC=selene/+/telemetry
MQTT_USER=selene
MQTT_PASSWORD=selene123
