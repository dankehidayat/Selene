# [apps/backend] production env — VPS path: apps/backend/.env
# Compose: env_file: ./apps/backend/.env
# Compose also overrides DATABASE_URL / TIMESCALE_URL / MQTT_* / JWT from root .env
#
#   cp apps/backend/.env.example apps/backend/.env
#
# Hostnames below match Docker Compose service names on the VPS network.

PORT=8787
JWT_SECRET="CHANGE_ME_JWT_SECRET"

# Service DNS (not localhost) when running inside compose
DATABASE_URL=postgresql://selene_admin:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/selene
TIMESCALE_URL=postgresql://selene_ts:CHANGE_ME_TIMESCALE_PASSWORD@timescaledb:5432/selene_measurements

MQTT_HOST=emqx
MQTT_PORT=1883
MQTT_TOPIC=selene/+/telemetry
MQTT_USER=selene
MQTT_PASSWORD=CHANGE_ME_MQTT_PASSWORD
