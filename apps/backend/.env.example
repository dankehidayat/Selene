# PRODUCTION backend env — copy to apps/backend/.env on the VPS
# Compose also injects DATABASE_URL / TIMESCALE_URL / MQTT_* / JWT from root .env

PORT=8787
JWT_SECRET="CHANGE_ME_JWT_SECRET"
DATABASE_URL=postgresql://selene_admin:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/selene
TIMESCALE_URL=postgresql://selene_ts:CHANGE_ME_TIMESCALE_PASSWORD@timescaledb:5432/selene_measurements
MQTT_HOST=emqx
MQTT_PORT=1883
MQTT_TOPIC=selene/+/telemetry
MQTT_USER=selene
MQTT_PASSWORD=CHANGE_ME_MQTT_PASSWORD

# Email (Resend free tier) — never commit real keys
RESEND_API_KEY=
RESEND_FROM="Selene <onboarding@resend.dev>"
# Public frontend origin for password-reset links
APP_PUBLIC_URL=https://selene.dankehidayat.my.id
TOTP_ISSUER=Selene
