# [apps/backend] .env.example

# Server port
PORT=8787

# JWT secret for authentication (generate with: openssl rand -base64 64)
JWT_SECRET=your-generated-jwt-secret-here

# PostgreSQL connection string (user accounts, glossary, notifications)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/flowpoint

# TimescaleDB connection string (sensor readings)
# Use localhost:5433 for local development (Docker exposed port)
# Use timescaledb:5432 for Docker Compose internal networking
TIMESCALE_URL=postgresql://selene_ts:your-password@localhost:5433/selene_measurements