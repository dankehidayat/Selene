# =============================================================================
# LOCAL DEVELOPMENT (Mac) — reference values for docker-compose.local.yml
# Infra passwords are also hardcoded in docker-compose.local.yml for simplicity.
#
# Backend app env:  cp apps/backend/.env.local.example apps/backend/.env
# Frontend app env: cp apps/frontend/.env.local.example apps/frontend/.env
#
# Start infra:
#   docker compose -f docker-compose.local.yml up -d
# =============================================================================

POSTGRES_USER=selene_admin
POSTGRES_PASSWORD=local_dev_password
POSTGRES_DB=selene
# Host port published by compose.local (not 5432 — often used by Homebrew PG)
POSTGRES_HOST_PORT=5434

TIMESCALE_USER=selene_ts
TIMESCALE_PASSWORD=local_dev_password
TIMESCALE_DB=selene_measurements
TIMESCALE_HOST_PORT=5433

EMQX_NAME=selene-local
EMQX_DASHBOARD_USER=admin
EMQX_DASHBOARD_PASSWORD=admin123

BACKEND_PORT=8787
JWT_SECRET=local_dev_jwt_secret_do_not_use_in_production

# Local EMQX on published 1883 — or use tunnel: MQTT_PORT=1884 after ./scripts/mqtt-tunnel.sh
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_TOPIC=selene/+/telemetry
MQTT_USER=selene
MQTT_PASSWORD=selene123

VITE_API_BASE_URL=http://localhost:8787/api
FRONTEND_PORT=5173
