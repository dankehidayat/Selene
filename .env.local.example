# =============================================================================
# Selene — Environment Variables (Local Development)
# Copy this file to .env for local development on macOS
# =============================================================================

# ── PostgreSQL (User Accounts, Auth, Glossary) ─────────────
# Host port 5434 maps to container 5432 — avoids Homebrew PG on 5432
POSTGRES_USER=selene_admin
POSTGRES_PASSWORD=local_dev_password
POSTGRES_DB=selene
POSTGRES_HOST_PORT=5434

# ── TimescaleDB (Sensor Readings) ─────────────────────────
TIMESCALE_USER=selene_ts
TIMESCALE_PASSWORD=local_dev_password
TIMESCALE_DB=selene_measurements
TIMESCALE_HOST_PORT=5433

# ── EMQX MQTT Broker ──────────────────────────────────────
EMQX_NAME=selene-local
EMQX_ALLOW_ANONYMOUS=false
EMQX_AUTH_MECHANISM=password_based
EMQX_AUTH_BACKEND=built_in_database
EMQX_AUTH_USER_ID_TYPE=username
EMQX_DASHBOARD_USER=admin
EMQX_DASHBOARD_PASSWORD=admin123

# ── Backend ───────────────────────────────────────────────
BACKEND_PORT=8787
JWT_SECRET=local_dev_jwt_secret_do_not_use_in_production

# ── MQTT Ingestor ─────────────────────────────────────────
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_TOPIC=selene/+/telemetry
MQTT_USER=selene
MQTT_PASSWORD=selene123

# ── Frontend ──────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8787/api
FRONTEND_PORT=5173
