# .env.example

# JWT secret for authentication (generate with: openssl rand -base64 64)
JWT_SECRET=your-generated-jwt-secret-here

# Google Sheets CSV export URL for historical data
SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/1O_k61ffjeUfEyYZYfi4nW6AF-asfPCQIiUSkFhi2uyM/export?format=csv&gid=0

# PostgreSQL connection string
DATABASE_URL=postgresql://selene_admin:your-password@postgres:5432/selene

# Frontend API URL (for production, change to your domain)
VITE_API_BASE_URL=https://api.dankehidayat.my.id/api

# Blynk IoT server for live sensor data
BLYNK_SERVER_URL=http://iot.serangkota.go.id:8080
BLYNK_AUTH_TOKEN=your-blynk-auth-token