# .env.example

# JWT secret for authentication (generate with: openssl rand -base64 64)
JWT_SECRET=your-generated-jwt-secret-here

# PostgreSQL connection string (user accounts, glossary, notifications)
DATABASE_URL=postgresql://selene_admin:your-password@postgres:5432/selene

# TimescaleDB connection string (sensor readings)
TIMESCALE_URL=postgresql://selene_ts:your-password@timescaledb:5432/selene_measurements

# Frontend API URL (for production, change to your domain)
VITE_API_BASE_URL=https://selene.dankehidayat.my.id/api
