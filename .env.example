# =============================================================================
# Selene — Environment Variables (Production / VPS)
# Copy to `.env` on the server (same path compose uses: env_file: .env)
#
#   cp .env.example .env
#   # fill secrets — do NOT commit .env
#
# Mirrors the live VPS layout (users, DB names, hosts, ports, public API URL).
# Passwords below are PLACEHOLDERS only.
# =============================================================================

# ── PostgreSQL (User Accounts, Auth, Glossary) ─────────────
POSTGRES_USER=selene_admin
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_DB=selene

# ── TimescaleDB (Sensor Readings) ─────────────────────────
TIMESCALE_USER=selene_ts
TIMESCALE_PASSWORD=CHANGE_ME_TIMESCALE_PASSWORD
TIMESCALE_DB=selene_measurements

# ── EMQX MQTT Broker ──────────────────────────────────────
EMQX_NAME=selene
EMQX_ALLOW_ANONYMOUS=false
EMQX_AUTH_MECHANISM=password_based
EMQX_AUTH_BACKEND=built_in_database
EMQX_AUTH_USER_ID_TYPE=username
EMQX_DASHBOARD_USER=admin
EMQX_DASHBOARD_PASSWORD=CHANGE_ME_EMQX_DASHBOARD_PASSWORD

# ── Backend ───────────────────────────────────────────────
BACKEND_PORT=8787
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_JWT_SECRET

# ── MQTT Ingestor (backend → compose service "emqx") ─────
MQTT_HOST=emqx
MQTT_PORT=1883
MQTT_TOPIC=selene/+/telemetry
MQTT_USER=selene
# Must match the EMQX built-in user used by ESP32 firmware
MQTT_PASSWORD=CHANGE_ME_MQTT_PASSWORD

# ── Frontend (build arg VITE_API_BASE_URL) ────────────────
VITE_API_BASE_URL=https://selene.dankehidayat.my.id/api
FRONTEND_PORT=4173
