# Alias of .env.example (production / VPS).
# On the server the real file is named `.env` for `docker compose`.
# See docs/DEPLOYMENT.md
#
#   cp .env.production.example .env   # first time only — never overwrite secrets blindly

POSTGRES_USER=selene_admin
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_DB=selene
TIMESCALE_USER=selene_ts
TIMESCALE_PASSWORD=CHANGE_ME_TIMESCALE_PASSWORD
TIMESCALE_DB=selene_measurements
EMQX_NAME=selene
EMQX_ALLOW_ANONYMOUS=false
EMQX_AUTH_MECHANISM=password_based
EMQX_AUTH_BACKEND=built_in_database
EMQX_AUTH_USER_ID_TYPE=username
EMQX_DASHBOARD_USER=admin
EMQX_DASHBOARD_PASSWORD=CHANGE_ME_EMQX_DASHBOARD_PASSWORD
BACKEND_PORT=8787
JWT_SECRET=CHANGE_ME_JWT_SECRET

# ── Email (Resend free tier) + public URL for password-reset links ──
# Put the real key only on the server — never commit it.
RESEND_API_KEY=
RESEND_FROM=Selene <onboarding@resend.dev>
APP_PUBLIC_URL=https://selene.dankehidayat.my.id
TOTP_ISSUER=Selene

MQTT_HOST=emqx
MQTT_PORT=1883
MQTT_TOPIC=selene/+/telemetry
MQTT_USER=selene
MQTT_PASSWORD=CHANGE_ME_MQTT_PASSWORD
VITE_API_BASE_URL=https://selene.dankehidayat.my.id/api
FRONTEND_PORT=4173
